{
  "name": "unitcirclevr",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://mmongan.github.io/unitcircle",
  "scripts": {
    "graph:build": "tsx scripts/build-graph.ts",
    "graph:watch": "tsx scripts/FileWatcher.ts",
    "dev": "vite",
    "dev:watch": "concurrently \"npm run graph:watch\" \"npm run dev\"",
    "build": "npm run graph:build && tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/prismjs": "^1.26.6",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.0.0",
    "concurrently": "^8.2.2",
    "gh-pages": "^6.3.0",
    "jsdom": "^29.0.1",
    "tsx": "^4.7.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@babylonjs/core": "^8.54.3",
    "@babylonjs/loaders": "^8.54.3",
    "@babylonjs/serializers": "^8.54.3",
    "prismjs": "^1.30.0"
  }
}
